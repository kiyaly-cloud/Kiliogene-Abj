            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
        <versionString>2.0.1</versionString>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>sum of all duree absences</description>
        <name>sum_of_all_duree_absences</name>
        <label>sum of all duree absences</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_Total_Duree_Cumulee</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>loop_on_absence.duree__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>loop_on_absence</targetReference>
        </connector>
    </assignments>
    <description>Help to calculate year based on date_debut and send mail to supervisor of employe for valid or reject request absence</description>
    <environments>Default</environments>
    <formulas>
        <description>Durée de l&apos;absence</description>
        <name>duration_of_absence</name>
        <dataType>Number</dataType>
        <expression>( (5 * ( FLOOR( ( DATEVALUE({!$Record.EndDate__c}) - DATE( 1900, 1, 8) ) / 7 ) ) + MIN( 5, MOD( DATEVALUE({!$Record.EndDate__c}) - DATE( 1900, 1, 8), 7 ) ) )
-
(5 * ( FLOOR( ( DATEVALUE({!$Record.StartDate__c}) - DATE( 1900, 1, 8) ) / 7 ) ) + MIN( 5, MOD( DATEVALUE({!$Record.StartDate__c}) - DATE( 1900, 1, 8), 7 ) ) ) ) + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Transform picklist Year to text</description>
        <name>f_year_Text</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.annee__c})</expression>
    </formulas>
    <formulas>
        <description>Recupérer le total des jours utilisés</description>
        <name>Get_Total_jours_used</name>
        <dataType>Number</dataType>
        <expression>{!var_Total_Duree_Cumulee}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Recupérer  l&apos;année à partir de  la date d&apos;absence de l&apos;activité</description>
        <name>Get_Year_Date_Absence</name>
        <dataType>Number</dataType>
        <expression>YEAR(DATEVALUE({!$Record.StartDate__c}))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Get Year from Date</description>
        <name>Get_Year_From_DATE</name>
        <dataType>String</dataType>
        <expression>TEXT(YEAR(DATEVALUE({!$Record.StartDate__c})))</expression>
    </formulas>
    <formulas>
        <description>Get annual  solde of conges</description>
        <name>GetSoldeannuelbasedonabsencedays</name>
        <dataType>Number</dataType>
        <expression>({!Get_Infos_on_solde_conges.Solde_Disponible__c} + {!Get_Infos_on_solde_conges.UsedDays__c}) - {!var_Total_Duree_Cumulee}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Sum of days used</description>
        <name>Sum_days_used</name>
        <dataType>Number</dataType>
        <expression>{!Get_Infos_on_solde_conges.UsedDays__c} + {!$Record.duree__c}</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Update Year and send mail According Date of absence {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Year and send mail According Date of absence</label>
    <loops>
        <description>Loop on all absences for suming absence</description>
        <name>loop_on_absence</name>
        <label>loop on absence</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_All_absence_of_user_connected</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>sum_of_all_duree_absences</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Infos_on_solde_conges</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
