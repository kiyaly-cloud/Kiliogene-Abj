                <stringValue> &lt;p&gt;&lt;strong style=&quot;font-size: 16px; text-decoration: underline;&quot;&gt;Une demande d&apos;absence&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;A été adressée par : 
    &lt;strong style=&quot;color: rgb(39, 79, 50); font-size: 14px;&quot;&gt;
        {!$Record.Owner:User__NotFound.FirstName} {!$Record.Owner:User__NotFound.LastName}
