    <decisions>
        <description>Verifier si le mail du chef de projet est renseigne</description>
        <name>Verifier_si_le_mail_du_chef_de_projet_est_renseigne</name>
        <label>Verifier si le mail du chef de projet est renseigne</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Parcourir_tous_les_projets</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>mail du chef de projet  null et conditions non respectées</defaultConnectorLabel>
        <rules>
            <name>mail_du_chef_de_projet_non_null_et_conditions_respectees</name>
            <conditionLogic>1 AND ( 2 OR  3 OR 4 )</conditionLogic>
            <conditions>
                <leftValueReference>Parcourir_tous_les_projets.chef_projet__r.Email</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Parcourir_tous_les_projets.budget_c__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Parcourir_tous_les_projets.actual_cost__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Parcourir_tous_les_projets.health_project__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>DÉPASSEMENT BUDGET</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Parcourir_tous_les_projets.health_project__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>FIN IMMINENTE</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SEND_MAIL_TO_RESPONSABLE</targetReference>
            </connector>
            <label>mail du chef de projet non null et conditions  respectees</label>
        </rules>
    </decisions>
