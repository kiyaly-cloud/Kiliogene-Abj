<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Ce flow permet de faire la duplication des tâches chaque fois qu&apos;on change le propriétaire d&apos;une tâche</description>
    <environments>Default</environments>
    <interviewLabel>Duplication d&apos;un tâche {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Duplication d&apos;un tâche</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Creer_une_version_obsolete</name>
        <label>Créer une version obsolete</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>CurrencyIsoCode</field>
            <value>
                <elementReference>$Record__Prior.CurrencyIsoCode</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Date_de_fin__c</field>
            <value>
                <elementReference>$Record__Prior.Date_de_fin__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Date_debut__c</field>
            <value>
                <elementReference>$Record__Prior.Date_debut__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Detail_de_la_tache__c</field>
            <value>
                <elementReference>$Record__Prior.Detail_de_la_tache__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <stringValue>{!$Record__Prior.Name} ARCHIVEE Le {!$Flow.CurrentDateTime}</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>$Record__Prior.OwnerId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Priorite__c</field>
            <value>
                <elementReference>$Record__Prior.Priorite__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Projet__c</field>
            <value>
                <elementReference>$Record__Prior.Projet__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Statut__c</field>
            <value>
                <stringValue>Obsolete</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Tache_Parent__c</field>
            <value>
                <elementReference>$Record__Prior.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Taux__c</field>
            <value>
                <elementReference>$Record__Prior.Taux__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Type_de_tache__c</field>
            <value>
                <elementReference>$Record__Prior.Type_de_tache__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>User__c</field>
            <value>
                <elementReference>$Record__Prior.User__c</elementReference>
            </value>
        </inputAssignments>
        <object>Tache__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Creer_une_version_obsolete</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>OwnerId</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Tache__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
