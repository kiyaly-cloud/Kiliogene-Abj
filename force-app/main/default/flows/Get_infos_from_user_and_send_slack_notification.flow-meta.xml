    <formulas>
        <name>TacheURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_590},
            FIND(&apos;/services&apos;, {!$Api.Enterprise_Server_URL_590}) - 1)</expression>
    </formulas>
    <interviewLabel>Get  infos from user and send slack notification {!$Flow.CurrentDateTime}</interviewLabel>
