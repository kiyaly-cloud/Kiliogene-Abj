        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>InvalidDraft</status>
    <textTemplates>
        <description>send notification for new task</description>
        <name>new_task_notification_slack</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>:clipboard: *Nouvelle tâche Salesforce*

