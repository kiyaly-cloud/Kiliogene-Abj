<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>progression_pourcentage__c</fullName>
    <description>% Progression Projet</description>
    <formula>IF(
    total_taches__c &gt; 0,
    (Total_Progress_Sum__c / total_taches__c) / 100 ,
    0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>% Progression projet</inlineHelpText>
    <label>Taux d&apos;avancement</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
