<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>icone_statut__c</fullName>
    <description>Statut du projet</description>
    <externalId>false</externalId>
    <formula>IF(INCLUDES(Statut__c, &quot;Terminé&quot;), &quot;✅&quot;,
IF(INCLUDES(Statut__c, &quot;En cours&quot;), &quot;🟡&quot;,
IF(INCLUDES(Statut__c, &quot;En attente&quot;), &quot;🔴&quot;, 
&quot;⚪&quot;)))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Statut du projet</inlineHelpText>
    <label>Icone Statut</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
